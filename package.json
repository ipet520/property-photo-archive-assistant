{
  "name": "property-photo-archive-assistant",
  "version": "2.2.5",
  "description": "物业工作照片归档助手 - 本地桌面照片归档整理工具",
  "author": "Property Photo Archive Assistant",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "dist": "npm run build && cross-env ELECTRON_CACHE=.electron-cache ELECTRON_BUILDER_CACHE=.electron-builder-cache CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win portable nsis",
    "package": "npm run dist",
    "start": "electron .",
    "env:check": "node scripts/check-env.cjs",
    "clean": "node scripts/clean.cjs",
    "reinstall": "npm run clean && npm install",
    "verify": "npm run env:check && npm run build"
  },
  "build": {
    "appId": "com.property.photo.archive.assistant",
    "productName": "物业工作照片归档助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "**/*.json"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "物业工作照片归档助手"
    }
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "31.7.7",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10"
  }
}
